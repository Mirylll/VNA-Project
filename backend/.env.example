NODE_ENV=development
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=vna_user
DB_PASSWORD=vna_password
DB_NAME=vna_db

JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h

# Email/OTP Configuration
# Leave empty to use Ethereal (dev) - preview URL will be logged in console
MAIL_HOST=smtp.ethereal.email
MAIL_PORT=587
MAIL_USER=your-ethereal-email@ethereal.email
MAIL_PASSWORD=your-ethereal-password
MAIL_FROM=noreply@vna.local

# Database: set to 'true' for development (auto-create tables), 'false' for production (use migrations)
TYPEORM_SYNC=true

