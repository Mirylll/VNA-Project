NODE_ENV=development
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=vna_user
DB_PASSWORD=vna_password
DB_NAME=vna_db

JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h

# Email/OTP Configuration
# For Gmail, enable 2-Step Verification and use an App Password, not your normal password.
# If these values are empty, the app uses Ethereal test email and only logs a preview URL.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-real-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-real-email@gmail.com

# Database: set to 'true' for development (auto-create tables), 'false' for production (use migrations)
TYPEORM_SYNC=true

