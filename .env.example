# === SMTP Configuration for OTP emails ===
# Copy this file to .env and fill in your SMTP credentials.
# Docker Compose will read these values automatically.
#
# For Gmail: use an App Password (not your regular password)
#   1. Enable 2FA at https://myaccount.google.com/security
#   2. Generate App Password at https://myaccount.google.com/apppasswords
#   3. Use that 16-char password below
#
# For Zoho Mail:
#   MAIL_HOST=smtp.zoho.com
#   MAIL_PORT=587
#
# Leave MAIL_USER/MAIL_PASSWORD empty to use Ethereal (dev-only, emails won't reach real inbox)

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
